<Window x:Class="ProductManagementApp_20260319.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductManagementApp_20260319"
        mc:Ignorable="d"
        Style="{StaticResource Default}"
        WindowStartupLocation="CenterScreen"

        Title="HistoryWindow" Height="600" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="dataGrid" Margin="5" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="*"/>
                <DataGridTextColumn Header="Product Name" Binding="{Binding Product.ProductName}" Width="*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding ActionType}" Width="*"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="*"/>
                <DataGridTextColumn Header="Memo" Binding="{Binding Memo}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Margin="5" x:Name="updateButton" Click="updateButton_Click" Content="Update" HorizontalAlignment="Left"/>
    </Grid>
</Window>
