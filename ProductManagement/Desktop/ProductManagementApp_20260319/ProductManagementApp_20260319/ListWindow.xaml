<Window x:Class="ProductManagementApp_20260319.ListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductManagementApp_20260319"
        mc:Ignorable="d"
        Style="{StaticResource Default}"
        WindowStartupLocation="CenterScreen"

        Title="ListWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition />
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBox Width="200" Margin="5" x:Name="searchTextBox"/>
            <Button Margin="5" Name="searchButton" Click="searchButton_Click" Content="Search"/>
        </StackPanel>

        <DataGrid x:Name="dataGrid" Margin="5" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
                <DataGridTextColumn Header="Create Date" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="2*"/>
                <DataGridTextColumn Header="Last update date" Binding="{Binding LastUpdateDate, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button x:Name="updateButton" Click="updateButton_Click" Content="Update" Margin="5"/>
            <Button x:Name="deleteButton" Click="deleteButton_Click" Content="Delete" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
